{
  "name": "mnemochat",
  "version": "0.1.0",
  "description": "Local-first desktop app for AI roleplay and collaborative storytelling.",
  "author": "RianMorningstar",
  "private": true,
  "main": "dist/main/main/index.js",
  "scripts": {
    "gen:icons": "node scripts/generate-icons.mjs",
    "copy:main-assets": "node scripts/copy-main-assets.mjs",
    "dev": "npm run gen:icons && tsc -p tsconfig.main.json && npm run copy:main-assets && concurrently -k -n electron,tsc,vite \"cross-env ELECTRON_DISABLE_SANDBOX=1 electronmon .\" \"tsc -p tsconfig.main.json -w\" \"vite --config vite.config.ts\"",
    "build": "npm run gen:icons && tsc -p tsconfig.main.json && npm run copy:main-assets && vite build --config vite.config.ts",
    "package": "npm run build && electron-builder",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/pdfmake": "^0.3.2",
    "better-sqlite3": "^11.8.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.39.3",
    "fastify": "^5.2.1",
    "lucide-react": "^0.577.0",
    "pdfmake": "^0.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.30.5",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.4",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  },
  "build": {
    "appId": "com.mnemochat.app",
    "productName": "MnemoChat",
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "drizzle",
        "to": "drizzle"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build-resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build-resources/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build-resources/icon.png"
    },
    "directories": {
      "output": "release"
    }
  }
}
